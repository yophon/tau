.page {
	display: flex;
	flex-direction: column;
	height: 100vh;
	padding: 16rpx;
	box-sizing: border-box;
	background: #f5f5f7;
}

.config .field {
	background: #fff;
	border-radius: 8rpx;
	padding: 12rpx 16rpx;
	margin-bottom: 8rpx;
	font-size: 26rpx;
}

.messages {
	flex: 1;
	margin: 16rpx 0;
	overflow: hidden;
}

.msg {
	max-width: 85%;
	margin-bottom: 12rpx;
	padding: 14rpx 20rpx;
	border-radius: 12rpx;
	font-size: 28rpx;
	word-break: break-all;
}

.msg.user {
	margin-left: auto;
	background: #1a1a2e;
	color: #fff;
}

.msg.assistant {
	background: #fff;
}

.msg.tool,
.msg.system {
	background: transparent;
	color: #888;
	font-size: 24rpx;
	padding: 4rpx 8rpx;
}

.msg.error {
	border: 2rpx solid #e0245e;
}

.msg.aborted {
	border: 2rpx solid #e6a23c;
	color: #999;
}

.error-detail {
	display: block;
	margin-top: 8rpx;
	color: #e0245e;
	font-size: 22rpx;
}

.composer {
	display: flex;
	align-items: center;
	gap: 8rpx;
}

.composer .prompt {
	flex: 1;
	background: #fff;
	border-radius: 8rpx;
	padding: 14rpx 16rpx;
	font-size: 28rpx;
}
